# VitePress build output + cache
.vitepress/dist/
.vitepress/cache/

# Pages generated from canonical repo docs by sync-docs.mjs (do not edit/commit;
# the source of truth is docs/*.md and docs/adr/*.md).
reference.md
cli.md
furniture.md
analysis.md
intent.md
errors.md
spec.md
adr/0*.md
adr/index.md

# The ADR sidebar, generated from docs/adr/*.md by sync-docs.mjs and imported by
# .vitepress/config.ts (so the sidebar can never freeze behind the ADR directory).
.vitepress/theme/adr-data.js

# Example-gallery SVGs + the live-widget source data are regenerated from
# examples/*.arch by sync-docs.mjs.
public/examples/
.vitepress/theme/examples-data.js

# llms.txt map + full-context bundle, copied from the repo root by sync-docs.mjs.
public/llms.txt
public/llms-full.txt

# Machine-native artifacts + raw-markdown page copies, published at the site root
# by sync-docs.mjs (schema/gbnf from the repo root; the *.md are the unbannered
# canonical page bodies served at /<route>.md). Regenerated every build.
public/plan.schema.json
public/intent.schema.json
public/archlang.gbnf
public/reference.md
public/cli.md
public/furniture.md
public/analysis.md
public/intent.md
public/errors.md
public/spec.md

node_modules/

.vercel
