# A compact studio flat: one main room (the bed is furniture, so the room reads as
# "living", never a walk-through bedroom), a kitchenette linked by a cased opening,
# and a separate bathroom off the main room.
plan "Compact Studio" {
  units mm
  grid 50
  scale 1:50
  north up

  wall exterior thickness 200 { (0,0) (5000,0) (5000,6000) (0,6000) close }
  wall id=w_low partition thickness 100 { (0,4000) (5000,4000) }
  wall id=w_bk  partition thickness 100 { (2500,4000) (2500,6000) }

  room id=r_main at (0,0)      size 5000x4000 label "Studio Room" uses living
  room id=r_bath at (0,4000)   size 2500x2000 label "Bathroom"    uses bath
  room id=r_kit  at (2500,4000) size 2500x2000 label "Kitchenette" uses kitchen

  door    id=d_main at (2500,0)    width 1000 wall exterior hinge left swing in
  door    id=d_bath at (1250,4000) width 800  wall w_low   hinge left swing in
  opening id=o_kit  at (3750,4000) width 1000 wall w_low

  window at (0,2000)    width 1500 wall exterior
  window at (5000,2000) width 1500 wall exterior
  window at (5000,5000) width 900  wall exterior

  furniture bed  at (300,300)  size 1500x2000 label "Bed"
  furniture sofa at (3200,300) size 1600x800  label "Sofa"

  furniture kitchen_sink at (2800,4300) size 800x600
  furniture counter      at (3700,4300) size 600x600

  furniture shower at (1450,4900) size 900x900
  furniture wc     at (200,5100)  size 400x700
  furniture basin  at (200,4200)  size 600x450
}
