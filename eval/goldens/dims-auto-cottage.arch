# A compact cottage that relies on AUTO dimensioning: `dims auto all` draws the
# overall extents, each room's width+height in the page margin, and one call-out
# per distinct wall thickness — no hand-placed `dim` lines.
plan "Auto-Dimensioned Cottage" {
  units mm
  grid 50
  scale 1:50
  north up
  dims auto all

  wall exterior thickness 200 { (0,0) (6000,0) (6000,5000) (0,5000) close }
  wall id=w_div partition thickness 100 { (3500,0) (3500,5000) }
  wall partition thickness 100 { (3500,2600) (6000,2600) }

  room id=r_live at (0,0)      size 3500x5000 label "Living / Kitchen" uses living kitchen
  room id=r_bed  at (3500,0)   size 2500x2600 label "Bedroom"          uses bedroom
  room id=r_bath at (3500,2600) size 2500x2400 label "Bathroom"        uses bath

  door    id=d_main at (1750,5000) width 1000 wall exterior  hinge left  swing in
  opening id=o_bed  at (3500,1300) width 900  wall w_div
  door    id=d_bath at (3500,3800) width 800  wall w_div     hinge right swing in

  window at (0,2500)    width 1500 wall exterior
  window at (5000,0)    width 1200 wall exterior
  window at (6000,3800) width 700  wall exterior

  furniture kitchen_sink at (300,300)  size 800x600
  furniture counter      at (1200,300) size 600x600
  furniture stove        at (1900,300) size 600x600

  furniture shower at (4800,4000) size 900x900
  furniture wc     at (3800,4100) size 400x700
  furniture basin  at (3800,2800) size 600x450
}
