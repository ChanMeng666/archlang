# A one-bedroom flat on an L-shaped footprint (the exterior wall is a six-point
# polygon, not a rectangle). The living room wraps the inner corner; kitchen,
# bedroom, and bath each open off it.
plan "L-Shaped Flat" {
  units mm
  grid 50
  scale 1:100
  north up

  wall exterior thickness 200 { (0,0) (9000,0) (9000,5000) (5000,5000) (5000,8000) (0,8000) close }
  wall id=w_lk partition thickness 100 { (5000,0) (5000,5000) }
  wall id=w_lb partition thickness 100 { (0,5000) (5000,5000) }
  wall id=w_bb partition thickness 100 { (3000,5000) (3000,8000) }

  room id=r_live    at (0,0)      size 5000x5000 label "Living"   uses living
  room id=r_kitchen at (5000,0)   size 4000x5000 label "Kitchen"  uses kitchen
  room id=r_bed     at (0,5000)   size 3000x3000 label "Bedroom"  uses bedroom
  room id=r_bath    at (3000,5000) size 2000x3000 label "Bathroom" uses bath

  door    id=d_main at (2500,0)    width 1000 wall exterior hinge left  swing in
  opening id=o_kit  at (5000,2500) width 1400 wall w_lk
  door    id=d_bed  at (1500,5000) width 800  wall w_lb hinge left  swing in
  door    id=d_bath at (4000,5000) width 800  wall w_lb hinge right swing in

  window at (7000,0)    width 1800 wall exterior
  window at (9000,2500) width 1500 wall exterior
  window at (0,6500)    width 1500 wall exterior

  furniture kitchen_sink at (5300,300)  size 800x600
  furniture counter      at (6200,300)  size 600x600
  furniture stove        at (6900,300)  size 600x600

  furniture shower at (3900,7000) size 900x900
  furniture wc     at (3100,7100) size 400x700
  furniture basin  at (4100,6000) size 600x450
}
