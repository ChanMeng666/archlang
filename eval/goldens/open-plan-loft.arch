# An open-plan loft: the kitchen, dining, and living zones flow into one another
# through leaf-less cased `opening`s (no doors between them); the only enclosed room
# — the bathroom — gets a real door. Demonstrates the `opening` element for
# open-plan circulation.
plan "Open-Plan Loft" {
  units mm
  grid 50
  scale 1:100
  north up

  wall exterior thickness 200 { (0,0) (9000,0) (9000,6000) (0,6000) close }
  wall id=w_kd partition thickness 100 { (3000,0) (3000,6000) }
  wall id=w_dl partition thickness 100 { (6000,0) (6000,3000) }
  wall id=w_lb partition thickness 100 { (6000,3000) (9000,3000) }
  wall id=w_db partition thickness 100 { (6000,3000) (6000,6000) }

  room id=r_kitchen at (0,0)    size 3000x6000 label "Kitchen"  uses kitchen
  room id=r_dining  at (3000,0) size 3000x6000 label "Dining"   uses dining
  room id=r_living  at (6000,0) size 3000x3000 label "Living"   uses living
  room id=r_bath    at (6000,3000) size 3000x3000 label "Bathroom" uses bath

  door    id=d_main at (1500,6000) width 1000 wall exterior hinge left swing in
  opening id=o_kd   at (3000,3000) width 1600 wall w_kd
  opening id=o_dl   at (6000,1500) width 1600 wall w_dl
  door    id=d_bath at (7000,3000) width 800  wall w_lb hinge right swing out

  window at (0,3000)    width 1500 wall exterior
  window at (9000,1700) width 1800 wall exterior
  window at (4500,6000) width 1500 wall exterior

  furniture kitchen_sink at (300,300)  size 800x600
  furniture counter      at (1200,300) size 600x600
  furniture stove        at (1900,300) size 600x600

  furniture shower at (8000,4900) size 900x900
  furniture wc     at (6300,5100) size 400x700
  furniture basin  at (8300,3300) size 600x450
}
