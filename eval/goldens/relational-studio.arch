# One-bedroom flat laid out with RELATIONAL placement: only the living room is
# anchored with `at`; kitchen/bedroom/bath derive their positions from a neighbour
# via right-of / below / align / gap. Walls and openings are drawn on the resolved
# boundaries so every room is enclosed and reachable (the bath opens off the
# kitchen, never through the bedroom).
plan "Relational 1BR" {
  units mm
  grid 50
  scale 1:100
  north up

  wall exterior thickness 200 { (0,0) (8000,0) (8000,7500) (0,7500) close }
  wall id=w_vert partition thickness 100 { (5000,0) (5000,7500) }
  wall partition thickness 100 { (0,4000) (8000,4000) }

  room id=living  at (0,0)                        size 5000x4000 label "Living"        uses living
  room id=kitchen right-of living align top gap 0 size 3000x4000 label "Kitchen"       uses kitchen
  room id=bed     below living    align left gap 0 size 5000x3500 label "Bedroom"      uses bedroom
  room id=bath    right-of bed    align top gap 0  size 3000x3500 label "Bathroom"     uses bath

  door    id=d_main at (2000,0)    width 1000 wall exterior hinge left  swing in
  opening id=o_kit  at (5000,2000) width 1000 wall w_vert
  door    id=d_bed  at (2500,4000) width 800  wall partition hinge left  swing in
  door    id=d_bath at (6500,4000) width 800  wall partition hinge right swing in

  window at (0,5750)   width 1500 wall exterior
  window at (8000,2000) width 1200 wall exterior

  furniture kitchen_sink at (5300,300)  size 800x600
  furniture counter      at (6200,300)  size 600x600
  furniture stove        at (6900,300)  size 600x600

  furniture shower at (6900,6400) size 900x900
  furniture wc     at (5300,6600) size 400x700
  furniture basin  at (5300,4300) size 600x450

  dim (0,7500)->(8000,7500) offset 600 text "8000"
}
