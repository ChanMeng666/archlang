# Circulation-diff fixture B — a copy of diff-circ-a.arch with EXACTLY one change:
#   the interior door `d_int` is relocated 3000 mm down the partition
#   (y=1000 -> y=4000), same width 800, same id.
# Room geometry, door/window count and all widths are identical to A, so the sole
# semantic delta is the walk distance from the entrance into `bed`. Compiles with
# zero errors. Used by test/diff.test.ts.
plan "Circ Diff Fixture" {
  units mm
  grid 50

  wall exterior  thickness 200 { (0,0) (7000,0) (7000,5000) (0,5000) close }
  wall partition thickness 100 { (4000,0) (4000,5000) }

  room id=living at (0,0)    size 4000x5000 label "Living"  uses living
  room id=bed    at (4000,0) size 3000x5000 label "Bedroom" uses bedroom

  door id=d_main at (2000,5000) width 1000 wall exterior  hinge left swing in
  # Interior door living <-> bed, now low on the partition (moved 3000 mm from A).
  door id=d_int  at (4000,4000) width 800  wall partition hinge left swing in

  window id=w1 at (0,2500) width 1200 wall exterior
}
