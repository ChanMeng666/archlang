{
  "name": "@chanmeng666/archlang",
  "version": "1.3.0",
  "description": "A small declarative language that compiles to professional SVG floor plans — like Typst/LaTeX, but for architecture.",
  "keywords": [
    "architecture",
    "floor-plan",
    "dsl",
    "compiler",
    "svg",
    "cad",
    "typst",
    "parametric",
    "language"
  ],
  "license": "MIT",
  "author": "Chan Meng <chanmeng.dev@gmail.com>",
  "homepage": "https://github.com/chanmeng666/archlang#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chanmeng666/archlang.git"
  },
  "bugs": {
    "url": "https://github.com/chanmeng666/archlang/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "arch": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "spec.llm.md",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "editors/vscode",
    "playground",
    "docs-site"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli.ts",
    "bench": "tsx bench/run.ts",
    "bench:json": "tsx bench/run.ts --json",
    "gen:grammars": "tsx scripts/gen-grammars.ts",
    "gen:errors": "tsx scripts/gen-error-codes.ts",
    "gen:spec": "tsx scripts/gen-llm-spec.ts",
    "eval": "tsx eval/run.ts",
    "docs:dev": "npm run build && npm -w docs-site run dev",
    "docs:build": "npm run build && npm -w docs-site run build",
    "playground:dev": "npm run build && npm -w archlang-playground run dev",
    "playground:build": "npm run build && npm -w archlang-playground run build",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pngjs": "^6.0.5",
    "fast-check": "^4.8.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "optionalDependencies": {
    "@resvg/resvg-js": "2.6.2",
    "clipper2-wasm": "0.4.0",
    "pdfkit": "^0.15.2"
  }
}
